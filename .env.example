# ========================================
# CONFIGURACIÓN SIFEN - FACTURACIÓN ELECTRÓNICA
# ========================================

# ----------------------------------------
# Modo de Operación
# ----------------------------------------
# Usar Mock-SET (true) o SET Real (false)
# Para producción: dejar en false o comentar
SIFEN_USAR_MOCK=true

# URL del servidor Mock-SET (solo desarrollo)
SIFEN_MOCK_URL=http://localhost:8082

# ----------------------------------------
# Ambiente de SET (solo producción)
# ----------------------------------------
# Valores: 'test' | 'prod'
# Solo aplica cuando SIFEN_USAR_MOCK=false
SIFEN_AMBIENTE=test

# ----------------------------------------
# Timeout y Debug
# ----------------------------------------
# Timeout para requests HTTP (milisegundos)
SIFEN_TIMEOUT=30000

# Habilitar logs de debug
SIFEN_DEBUG=false

# ----------------------------------------
# MongoDB
# ----------------------------------------
MONGODB_URI=mongodb://localhost:27017/sifen_db

# ----------------------------------------
# Servidor Backend
# ----------------------------------------
PORT=8081

# ----------------------------------------
# JWT (Autenticación)
# ----------------------------------------
JWT_SECRET=tu_secreto_super_secreto_cambiar_en_produccion
JWT_EXPIRES_IN=24h
